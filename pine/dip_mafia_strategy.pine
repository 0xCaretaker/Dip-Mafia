//@version=6
// =============================================================================
// Dip Mafia - STRATEGY backtest variant (long-only, HODL, NEVER sells)
//
// Same signal layer as dip_mafia.pine (BB(200) gate + MACD / Impulse MACD), but
// wired into strategy() so TradingView produces an equity curve.
//
// INVARIANT preserved: this strategy ONLY enters. There is no exit, stop, or
// take-profit anywhere in this file. Every BUY accumulates and is held forever.
// "Weakness" crossovers are plotted for awareness only and are never traded.
//
// This is a per-symbol approximation of "Timed HODL": it deploys a fixed cash
// tranche on each gated buy. It does NOT model the portfolio-level fallback
// averaging, 15%-per-stock cap, or SIP split - those need a shared cash pool
// across the whole watchlist and live in backtest.py.
// =============================================================================
strategy("Dip Mafia HODL (long-only, never sells)", overlay = true,
     pyramiding = 1000, calc_on_every_tick = false,
     initial_capital = 1000000, currency = currency.NONE,
     default_qty_type = strategy.cash, default_qty_value = 10000,
     commission_type = strategy.commission.percent, commission_value = 0.05)

// ---------- Inputs ----------------------------------------------------------
bbLength        = input.int(200,  "Bollinger length",            minval = 1, group = "Bollinger gate")
bbStdDev        = input.float(2.0,"Bollinger std dev",           step = 0.1, group = "Bollinger gate")
watchLookback   = input.int(60,   "Watch lookback (bars)",       minval = 1, group = "Bollinger gate")
requireBelowMid = input.bool(false,"Require close < BB midline (backtest stricter mode)", group = "Bollinger gate",
     tooltip = "Live bot = false. backtest.py BUY_REQUIRE_BELOW_MID = true.")

macdFast = input.int(12, "MACD fast EMA",   group = "Standard MACD")
macdSlow = input.int(26, "MACD slow EMA",   group = "Standard MACD")
macdSig  = input.int(9,  "MACD signal EMA", group = "Standard MACD")

impLenMA = input.int(34, "Impulse MA length",     group = "Impulse MACD")
impSig   = input.int(9,  "Impulse signal length", group = "Impulse MACD")

signalSrc = input.string("Either", "MACD trigger",
     options = ["Standard", "Impulse", "Either", "Both"], group = "Combine")

oncePerBar = input.bool(true, "Max one buy per bar", group = "Sizing",
     tooltip = "Standard and Impulse can both cross up on the same bar; this avoids double-tranche entries.")

rfAnnual = input.float(6.0, "Risk-free rate % (annual)", group = "Metrics",
     tooltip = "Used for Sharpe/Sortino. 6% matches the India risk-free rate in backtest.py.")
showMetrics = input.bool(true, "Show performance table", group = "Metrics")

// ---------- Bollinger Bands (length=200, 2σ; sample stdev) ------------------
basis = ta.sma(close, bbLength)
dev   = ta.stdev(close, bbLength, false)
upper = basis + bbStdDev * dev
lower = basis - bbStdDev * dev

plot(basis, "BB Mid (200 SMA)", color = color.new(color.orange, 0))
pU = plot(upper, "BB Upper", color = color.new(color.gray, 50))
pL = plot(lower, "BB Lower", color = color.new(color.gray, 50))
fill(pU, pL, color = color.new(color.blue, 92), title = "BB envelope")

touched    = (low <= lower) or (close <= lower)
bsTouch    = ta.barssince(touched)
bbBuy      = touched
bbWatch    = (not touched) and (not na(bsTouch)) and (bsTouch <= watchLookback)
inUniverse = bbBuy or bbWatch
midOk      = (not requireBelowMid) or (close < basis)

// ---------- Standard MACD (12/26/9) -----------------------------------------
emaFast  = ta.ema(close, macdFast)
emaSlow  = ta.ema(close, macdSlow)
macdLine = emaFast - emaSlow
sigLine  = ta.ema(macdLine, macdSig)
stdBuy   = ta.crossover(macdLine, sigLine)
stdSell  = ta.crossunder(macdLine, sigLine)

// ---------- Impulse MACD (LazyBear variant, per macd_signals.py) ------------
hlc3src = (high + low + close) / 3
hi = ta.rma(high, impLenMA)        // SMMA == Pine RMA
lo = ta.rma(low,  impLenMA)
e1 = ta.ema(hlc3src, impLenMA)
e2 = ta.ema(e1, impLenMA)
mi = e1 + (e1 - e2)                // repo's calc_zlema == DEMA
md = mi > hi ? mi - hi : (mi < lo ? mi - lo : 0.0)
sb = ta.sma(md, impSig)
impBuy  = ta.crossover(md, sb)
impSell = ta.crossunder(md, sb)

// ---------- Combine ---------------------------------------------------------
macdBuy = signalSrc == "Standard" ? stdBuy :
          signalSrc == "Impulse"  ? impBuy :
          signalSrc == "Both"     ? (stdBuy and impBuy) :
                                     (stdBuy or  impBuy)
macdSell = signalSrc == "Standard" ? stdSell :
           signalSrc == "Impulse"  ? impSell :
           signalSrc == "Both"     ? (stdSell and impSell) :
                                      (stdSell or  impSell)

dipBuy = macdBuy and inUniverse and midOk

// ---------- Execution: enter only, NEVER exit -------------------------------
// Need enough history for the 200-bar band to be defined before trading.
var int nBuys = 0
warmedUp = not na(lower)
if dipBuy and warmedUp
    // unique id per entry so each tranche shows separately under pyramiding
    eid = oncePerBar ? "Dip" : "Dip-" + str.tostring(bar_index)
    strategy.entry(eid, strategy.long)
    nBuys += 1

// There is intentionally NO strategy.close / strategy.exit anywhere. HODL.

// ---------- Performance metrics (equity-curve based) ------------------------
// A never-sell strategy has ZERO closed trades, so TradingView's Strategy Tester
// leaves trade-based stats (win %, profit factor, avg trade - and often Sharpe)
// blank or 0. We instead compute return/risk from the equity curve itself, using
// the same conventions as backtest.py compute_metrics(): per-day excess return
// over a 6% risk-free, sample stdev, sqrt(252) annualization, Sortino measured on
// the negative-excess subset. These are time-weighted (not the dashboard's
// money-weighted XIRR), so treat them as comparable-in-spirit, not identical.
var float startEq   = na     // equity at first entry
var int   startTime = na
var float prevEq    = na
var int   nObs      = 0
var float sumEx     = 0.0
var float sumEx2    = 0.0
var int   nNeg      = 0
var float sumNeg    = 0.0
var float sumNeg2   = 0.0
var float peakEq    = na
var float maxDD     = 0.0     // most negative (equity - peak)/peak

rfDaily = math.pow(1.0 + rfAnnual / 100.0, 1.0 / 252.0) - 1.0
inMarket = strategy.position_size > 0
if inMarket
    if na(startEq)
        startEq   := strategy.equity
        startTime := time
        peakEq    := strategy.equity
    else if prevEq > 0
        ret = strategy.equity / prevEq - 1.0
        ex  = ret - rfDaily
        nObs   += 1
        sumEx  += ex
        sumEx2 += ex * ex
        if ex < 0
            nNeg    += 1
            sumNeg  += ex
            sumNeg2 += ex * ex
        peakEq := math.max(peakEq, strategy.equity)
        maxDD  := math.min(maxDD, (strategy.equity - peakEq) / peakEq)
    prevEq := strategy.equity

// ---------- Performance table (drawn on the last bar) -----------------------
var table perf = table.new(position.top_right, 2, 11, border_width = 1,
     frame_color = color.gray, frame_width = 1)

// helper must live in global scope (Pine forbids function defs inside if-blocks)
metricRow(r, k, v) =>
    bg = color.new(color.black, 15)
    table.cell(perf, 0, r, k, text_color = color.white, text_size = size.small,
         text_halign = text.align_left,  bgcolor = bg)
    table.cell(perf, 1, r, v, text_color = color.white, text_size = size.small,
         text_halign = text.align_right, bgcolor = bg)

if showMetrics and barstate.islast
    meanEx  = nObs > 0 ? sumEx / nObs : 0.0
    varEx   = nObs > 1 ? (sumEx2 - nObs * meanEx * meanEx) / (nObs - 1) : 0.0
    stdEx   = varEx > 0 ? math.sqrt(varEx) : 0.0
    meanNeg = nNeg > 0 ? sumNeg / nNeg : 0.0
    varNeg  = nNeg > 1 ? (sumNeg2 - nNeg * meanNeg * meanNeg) / (nNeg - 1) : 0.0
    stdNeg  = varNeg > 0 ? math.sqrt(varNeg) : 0.0
    ann     = math.sqrt(252)
    sharpe  = stdEx  > 0 ? ann * meanEx / stdEx  : 0.0
    sortino = stdNeg > 0 ? ann * meanEx / stdNeg : 0.0
    vol     = stdEx * ann * 100.0
    yrs     = na(startTime) ? 0.0 : (time - startTime) / (1000.0 * 60 * 60 * 24 * 365.25)
    tr      = na(startEq) or startEq == 0 ? 0.0 : strategy.equity / startEq - 1.0
    cagr    = yrs > 0 ? (math.pow(1.0 + tr, 1.0 / yrs) - 1.0) * 100.0 : 0.0
    calmar  = maxDD < 0 ? (cagr / 100.0) / math.abs(maxDD) : 0.0

    hd = color.new(color.teal, 0)
    table.cell(perf, 0, 0, "Dip Mafia HODL - equity metrics", text_color = color.white,
         text_size = size.small, bgcolor = hd)
    table.cell(perf, 1, 0, "", bgcolor = hd)
    metricRow(1,  "Total return",   str.tostring(tr * 100.0, "#.##") + "%")
    metricRow(2,  "CAGR",           str.tostring(cagr, "#.##") + "%")
    metricRow(3,  "Sharpe",         str.tostring(sharpe, "#.##"))
    metricRow(4,  "Sortino",        str.tostring(sortino, "#.##"))
    metricRow(5,  "Max drawdown",   str.tostring(maxDD * 100.0, "#.##") + "%")
    metricRow(6,  "Volatility",     str.tostring(vol, "#.##") + "% / yr")
    metricRow(7,  "Calmar",         str.tostring(calmar, "#.##"))
    metricRow(8,  "Open P&L",       str.tostring(strategy.openprofit, "#"))
    metricRow(9,  "Equity",         str.tostring(strategy.equity, "#"))
    metricRow(10, "Buys / open lots", str.tostring(nBuys) + " / " + str.tostring(strategy.opentrades))

// ---------- Markers ---------------------------------------------------------
plotshape(dipBuy and warmedUp, "Dip BUY", shape.triangleup, location.belowbar,
     color.new(color.green, 0), size = size.small, text = "BUY")
plotshape(macdSell, "Weakness (info only, never sold)", shape.triangledown, location.abovebar,
     color.new(color.red, 25), size = size.tiny, text = "weak")
bgcolor(bbBuy ? color.new(color.green, 90) : na, title = "Lower-band touch zone")
